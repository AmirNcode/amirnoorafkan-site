---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Stats from '../components/Stats.astro';
import Projects from '../components/Projects.astro';
import LedgerSection from '../components/LedgerSection.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Amir Noorafkan — Engineer & Developer in Toronto"
  description="Amir Noorafkan is an engineer and developer in Toronto. He ran cost control on $160M of construction including two grid-scale battery storage projects, and builds web apps."
>
  <Nav />
  <main>
    <Hero />
    <Stats />
    <Projects />
    <LedgerSection />
    <About />
  </main>
  <Footer />
</BaseLayout>
