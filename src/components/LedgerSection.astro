---
import Ledger from './Ledger';
import { ledger } from '../data/ledger';
---

<section id="ledger" aria-labelledby="ledger-heading">
  <div class="container">
    <p class="kicker">02 / The record</p>
    <h2 id="ledger-heading">The Ledger</h2>
    <p class="section-lede">
      A running account of what I’ve built, shipped, and been trusted with. Kept here partly for
      you — mostly for me.
    </p>
    <Ledger client:idle entries={ledger} />
  </div>
</section>

<style is:global>
  #ledger .section-lede {
    margin-top: 0.75rem;
    color: var(--muted);
    max-width: 52ch;
  }

  .ledger-list {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }

  .ledger-list .row {
    border-bottom: 1px solid var(--line);
    border-left: 2px solid transparent;
    transition: border-left-color 200ms ease, background-color 200ms ease;
  }

  .ledger-list .row:hover,
  .ledger-list .row.open {
    border-left-color: var(--accent);
    background: color-mix(in srgb, var(--surface) 55%, transparent);
  }

  .ledger-list .row-head {
    display: grid;
    grid-template-columns: 8.5rem 1fr auto 1.5rem;
    align-items: baseline;
    gap: 1rem;
    width: 100%;
    padding: 1.0625rem 0.875rem 1.0625rem 1rem;
    text-align: left;
  }

  .ledger-list .period {
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .ledger-list .row-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.0625rem;
  }

  .ledger-list .value {
    font-size: 0.8125rem;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }

  .ledger-list .indicator {
    color: var(--muted);
    font-size: 0.9375rem;
    text-align: center;
  }

  .ledger-list .row:hover .indicator {
    color: var(--accent);
  }

  .ledger-list .detail {
    display: grid;
    grid-template-rows: 1fr;
    transition: grid-template-rows 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ledger-list[data-hydrated] .row:not(.open) .detail {
    grid-template-rows: 0fr;
  }

  .ledger-list .detail-inner {
    overflow: hidden;
  }

  .ledger-list .detail-inner p {
    padding: 0 1rem 1.25rem 9.5rem;
    max-width: 62ch;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--muted);
  }

  .ledger-list .detail-link {
    font-size: 0.8125rem;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
  }

  .ledger-list .detail-link:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }

  @media (max-width: 719px) {
    .ledger-list .row-head {
      grid-template-columns: 1fr auto 1.25rem;
      grid-template-areas:
        'period value indicator'
        'title title title';
      row-gap: 0.25rem;
    }

    .ledger-list .period {
      grid-area: period;
    }

    .ledger-list .row-title {
      grid-area: title;
    }

    .ledger-list .value {
      grid-area: value;
    }

    .ledger-list .indicator {
      grid-area: indicator;
    }

    .ledger-list .detail-inner p {
      padding-left: 1rem;
    }
  }
</style>
