---
import { Image } from 'astro:assets';
import type { Project } from '../data/projects';
import type { ImageMetadata } from 'astro';

interface Props {
  project: Project;
  shot: ImageMetadata;
}

const { project, shot } = Astro.props;
const domain = new URL(project.live).hostname;
---

<article class="card">
  <a class="shot-link" href={project.live} target="_blank" rel="noopener" aria-label={`Open ${project.title} (live site)`}>
    <div class="browser-frame">
      <div class="browser-bar" aria-hidden="true">
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="domain mono">{domain}</span>
      </div>
      <Image src={shot} alt={project.shotAlt} widths={[420, 840]} sizes="(max-width: 960px) 92vw, 340px" />
    </div>
  </a>
  <div class="card-body">
    <h3>
      <a href={project.live} target="_blank" rel="noopener">{project.title}<span class="arrow" aria-hidden="true">↗</span></a>
    </h3>
    <p class="pitch">{project.pitch}</p>
    <p class="desc">{project.description}</p>
    <ul class="chips mono" aria-label="Technology used">
      {project.tech.map((t) => <li>{t}</li>)}
    </ul>
    <div class="links mono">
      <a href={project.live} target="_blank" rel="noopener">Live ↗</a>
      <a href={project.source} target="_blank" rel="noopener">Source ↗</a>
    </div>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1), border-color 220ms ease, box-shadow 220ms ease;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--accent) 55%, var(--line));
    box-shadow: var(--shadow);
  }

  .shot-link {
    display: block;
  }

  .browser-frame {
    border-bottom: 1px solid var(--line);
  }

  .browser-bar {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--line);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--line);
  }

  .card:hover .dot:first-child {
    background: var(--accent);
  }

  .domain {
    margin-left: 0.5rem;
    font-size: 0.6875rem;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .browser-frame :global(img) {
    width: 100%;
    height: auto;
    aspect-ratio: 8 / 5;
    object-fit: cover;
    object-position: top;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.25rem 1.25rem 1.375rem;
    gap: 0.625rem;
  }

  h3 {
    font-size: 1.1875rem;
    font-weight: 700;
  }

  h3 a {
    text-decoration: none;
  }

  .arrow {
    display: inline-block;
    margin-left: 0.375rem;
    font-size: 0.875em;
    color: var(--accent);
    transition: transform 180ms ease;
  }

  .card:hover .arrow {
    transform: translate(2px, -2px);
  }

  .pitch {
    font-size: 0.9375rem;
    color: var(--text);
    font-weight: 500;
  }

  .desc {
    font-size: 0.9063rem;
    color: var(--muted);
    line-height: 1.6;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin-top: auto;
  }

  .chips li {
    font-size: 0.6875rem;
    padding: 0.25rem 0.5625rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--muted);
  }

  .links {
    display: flex;
    gap: 1.25rem;
    font-size: 0.8125rem;
    padding-top: 0.375rem;
    border-top: 1px dashed var(--line);
  }

  .links a {
    text-decoration: none;
    color: var(--accent);
  }
</style>
