# Cloudflare Pages / Netlify header rules (copied to dist/ at build).
# Firebase uses firebase.json instead; this keeps caching parity on Pages.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/og.png
  Cache-Control: public, max-age=604800

/*.pdf
  Cache-Control: public, max-age=604800

/favicon.svg
  Cache-Control: public, max-age=604800
